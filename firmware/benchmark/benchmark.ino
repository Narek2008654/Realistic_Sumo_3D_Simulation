// benchmark.ino — measure mini_sumo_ai::predict_motors() latency.
//
// Drop the trained header (neural_net_v4.h, generated by
// export_weights.py) next to this sketch. Flash, open Serial Monitor
// at 115200 baud, and wait a few seconds for output.
//
// Output:
//   selftest max delta: <float>     (parity with Python; < 1e-3 healthy)
//   forward pass: n=1000  mean=<us>  max=<us>  total=<us>
//   last action: (out_l, out_r)     (printed so the compiler can't
//                                   optimise the predict loop away)
//
// Use the mean to validate STEP_DT_SECONDS in sumo_env.py:
//   STEP_DT_SECONDS = SUBSTEPS_PER_STEP * SIM_TIMESTEP  (Python = 41.67 ms)
// Real Arduino loop dt = sensor read + predict_motors + motor update.
// Aim for predict_motors << STEP_DT_SECONDS so the rest of the loop
// fits in budget.

#include "neural_net_v4.h"

constexpr uint16_t N_ITERATIONS = 1000;

// Dummy observation — non-zero across the obs vector so every layer
// of the network sees real activations and the LUT branch we exercise
// is representative. Values come from the env's normalised range:
//   front/left/right ∈ [0, 1], last_seen ∈ {-1, 0, +1}, line_* ∈ {0, 1},
//   prev_left/right ∈ [-1, +1], engagement ∈ [0, 1], yaw_rate ∈ [-1, +1].
const float DUMMY_OBS[mini_sumo_ai::INPUT_DIM] = {
    0.50f,  // front
    0.30f,  // left
    0.70f,  // right
   +1.0f,   // last_seen (right)
    0.0f,   // line_l
    1.0f,   // line_r (rear-right edge sensor lit)
   +0.4f,   // prev_left
   -0.2f,   // prev_right
    0.6f,   // engagement (~18 ticks of close-front lock)
   +0.3f    // yaw_rate_proxy (mild rightward turn)
};

void setup() {
    Serial.begin(115200);
    // Wait for USB-CDC up to 3 s so the host has time to attach.
    while (!Serial && millis() < 3000) {}

    Serial.println(F("=== mini_sumo_ai inference benchmark ==="));
    Serial.print(F("INPUT_DIM=")); Serial.print(mini_sumo_ai::INPUT_DIM);
    Serial.print(F("  H1=")); Serial.print(mini_sumo_ai::H1_DIM);
    Serial.print(F("  H2=")); Serial.print(mini_sumo_ai::H2_DIM);
    Serial.print(F("  OUTPUT_DIM=")); Serial.println(mini_sumo_ai::OUTPUT_DIM);

    // ---- 1. Self-test parity check ---------------------------------
    const float selftest_delta = mini_sumo_ai::verify_self_test();
    Serial.print(F("selftest max delta: "));
    Serial.println(selftest_delta, 6);
    if (selftest_delta > 1.0e-3f) {
        Serial.println(
            F("  WARNING: weight or LUT corruption suspected (>1e-3)")
        );
    }

    // ---- 2. Latency benchmark --------------------------------------
    float out_l = 0.0f, out_r = 0.0f;
    uint32_t total_us = 0;
    uint32_t max_us = 0;

    for (uint16_t k = 0; k < N_ITERATIONS; ++k) {
        const uint32_t t0 = micros();
        mini_sumo_ai::predict_motors(
            DUMMY_OBS[0], DUMMY_OBS[1], DUMMY_OBS[2],
            DUMMY_OBS[3], DUMMY_OBS[4], DUMMY_OBS[5],
            DUMMY_OBS[6], DUMMY_OBS[7], DUMMY_OBS[8],
            DUMMY_OBS[9],
            out_l, out_r
        );
        const uint32_t dt = micros() - t0;
        total_us += dt;
        if (dt > max_us) max_us = dt;
    }

    const float mean_us = (float)total_us / (float)N_ITERATIONS;
    Serial.print(F("forward pass: n="));
    Serial.print(N_ITERATIONS);
    Serial.print(F("  mean=")); Serial.print(mean_us, 2);
    Serial.print(F(" us  max=")); Serial.print(max_us);
    Serial.print(F(" us  total=")); Serial.print(total_us);
    Serial.println(F(" us"));

    // ---- 3. Anti-elision printout ----------------------------------
    // Force the compiler to keep predict_motors live by reading the
    // outputs after the loop. Without this, -O2 may optimise the
    // entire benchmark away.
    Serial.print(F("last action: ("));
    Serial.print(out_l, 4); Serial.print(F(", "));
    Serial.print(out_r, 4); Serial.println(F(")"));

    Serial.println(F("=== done ==="));
}

void loop() {
    // No-op. Reset / re-flash to re-run.
}
