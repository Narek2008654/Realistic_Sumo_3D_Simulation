<?xml version="1.0"?>
<!--
  Mini Sumo agent — 400 RPM upgrade.

  Frame convention:
    base_link origin sits at the centre of the 99.25 × 98 mm footprint,
    on the floor plane. +X is forward, +Y is left, +Z is up.

  Outer dimensions:
    Total length (X) : 99.25 mm   ( front +0.0496, rear -0.0496 )
    Total width  (Y) : 98 mm      ( ±0.049 )
    Chassis box      : 82.2 × 98 × 40 mm  ( -0.0496 ≤ x ≤ +0.0326 )
    Wedge            : 17 mm long, slope 0.5 mm tip → 10 mm trailing edge

  Mass / CoM:
    Total                    : 0.45 kg
    CoM (relative to origin) : x = +0.0016 m  (48 mm behind the front tip)
                                y = 0
                                z = 0.007 m   (7 mm above floor)

  Wheels:
    Diameter 20 mm (r=0.010), width 19 mm. Track width 80.2 mm
    (axles at y = ±0.0401). Axle z = 0.010 so the chassis rides extremely
    low. Mounted near the rear at x = -0.025.
-->
<robot name="mini_sumo">

  <!-- ======================== CHASSIS ======================== -->
  <link name="base_link">
    <inertial>
      <!-- CoM 48 mm behind the front tip (= +0.0496 - 0.048 = +0.0016)
           and 7 mm above the floor; mass 0.45 kg. -->
      <origin xyz="0.0016 0.0 0.007" rpy="0 0 0"/>
      <mass value="0.45"/>
      <!-- Chassis-box principal moments at 0.45 kg:
           Ixx = (m/12)*(W^2 + H^2) = 4.20e-4
           Iyy = (m/12)*(L^2 + H^2) = 3.13e-4
           Izz = (m/12)*(L^2 + W^2) = 6.14e-4 -->
      <inertia ixx="4.20e-4" ixy="0" ixz="0"
               iyy="3.13e-4" iyz="0"
               izz="6.14e-4"/>
    </inertial>

    <visual>
      <!-- Chassis box centred between the rear face (-0.0496) and the
           wedge boundary (+0.0326) -> centre x = -0.0085. Bottom rests
           at z = 0 (wheels share that contact plane). -->
      <origin xyz="-0.0085 0.0 0.020" rpy="0 0 0"/>
      <geometry>
        <box size="0.0822 0.098 0.040"/>
      </geometry>
      <material name="red">
        <color rgba="0.85 0.15 0.15 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="-0.0085 0.0 0.020" rpy="0 0 0"/>
      <geometry>
        <box size="0.0822 0.098 0.040"/>
      </geometry>
    </collision>
  </link>

  <!-- ============== FRONT CASTER (invisible slider) ========== -->
  <link name="front_caster">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-9" ixy="0" ixz="0"
               iyy="1e-9" iyz="0"
               izz="1e-9"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.003"/>
      </geometry>
    </collision>
    <contact>
      <lateral_friction value="0.0"/>
      <rolling_friction value="0.0"/>
      <spinning_friction value="0.0"/>
    </contact>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="front_caster"/>
    <!-- Just behind the wedge mount, under the chassis bottom edge so
         the chassis nose can't snag if it tips forward. -->
    <origin xyz="0.025 0.0 0.003" rpy="0 0 0"/>
  </joint>

  <!-- ====================== NOSE WEDGE ======================= -->
  <!-- Slab geometry (in body frame):
         trailing edge (top, joins chassis) : x = +0.0326,  z = 0.010
         leading edge (sharp tip)           : x = +0.0496,  z = 0.0005
         slope length  = sqrt(17^2 + 9.5^2) = 19.48 mm
         pitch (about Y) = atan2(9.5, 17) = 0.5101 rad (~29 deg) -->
  <link name="nose_wedge">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <!-- Slab inertia for box (0.01948 x 0.098 x 0.002), m=0.02.
           Iyy bumped from computed 6.4e-7 to 1.5e-6 to give margin
           under PyBullet's strict triangle inequality. -->
      <inertia ixx="1.601e-5" ixy="0" ixz="0"
               iyy="1.5e-6"   iyz="0"
               izz="1.664e-5"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- slope-length × chassis-width × thin -->
        <box size="0.01948 0.098 0.002"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.78 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01948 0.098 0.002"/>
      </geometry>
    </collision>

    <contact>
      <!-- Slick face so it slides under the opponent rather than grabbing. -->
      <lateral_friction value="0.3"/>
    </contact>
  </link>

  <joint name="nose_wedge_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="nose_wedge"/>
    <!-- Slab centre at the midpoint of trailing and leading edges,
         rotated so its long axis runs down-slope. With pitch 0.5101 rad
         and 2 mm thickness, an origin z of 0.0061 places the leading-
         edge bottom corner at z ≈ 0.0005 (the spec'd lowest Z). -->
    <origin xyz="0.0411 0.0 0.0061" rpy="0 0.5101 0"/>
  </joint>

  <!-- ===================== LEFT WHEEL ======================== -->
  <link name="left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.025"/>
      <!-- Cylinder, r=0.010, h=0.019, axis along link +Y after the
           90 deg roll:
             Iyy (rolling)        = 0.5*m*r^2                = 1.25e-6
             Ixx = Izz            = (m/12)*(3*r^2 + h^2)     = 1.378e-6 -->
      <inertia ixx="1.378e-6" ixy="0" ixz="0"
               iyy="1.25e-6"  iyz="0"
               izz="1.378e-6"/>
    </inertial>

    <visual>
      <!-- Roll 90 deg so the cylinder lies on its side and rolls about Y. -->
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.019"/>
      </geometry>
      <material name="black">
        <color rgba="0.05 0.05 0.05 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.019"/>
      </geometry>
    </collision>

    <contact>
      <lateral_friction value="1.0"/>
    </contact>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <!-- Axle 25 mm behind centre, +40.1 mm to the left, 10 mm above
         floor so the chassis rides very low. -->
    <origin xyz="-0.025 0.0401 0.010" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===================== RIGHT WHEEL ======================= -->
  <link name="right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.025"/>
      <inertia ixx="1.378e-6" ixy="0" ixz="0"
               iyy="1.25e-6"  iyz="0"
               izz="1.378e-6"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.019"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.019"/>
      </geometry>
    </collision>

    <contact>
      <lateral_friction value="1.0"/>
    </contact>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="-0.025 -0.0401 0.010" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>
